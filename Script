local function MkSlider(parent,n,d,mn,mx,def,o,cb)
    local f=Instance.new("Frame",parent); f.Size=UDim2.new(1,0,0,52)
    f.BackgroundColor3=Color3.fromRGB(32,31,42); f.BorderSizePixel=0; f.LayoutOrder=o
    Instance.new("UICorner",f).CornerRadius=UDim.new(0,8)
    local nl=Instance.new("TextLabel",f); nl.Size=UDim2.new(1,-55,0,16); nl.Position=UDim2.new(0,12,0,4)
    nl.BackgroundTransparency=1; nl.Text=n; nl.TextColor3=Color3.fromRGB(200,196,232)
    nl.TextSize=12; nl.Font=Enum.Font.GothamSemibold; nl.TextXAlignment=Enum.TextXAlignment.Left
    local vl=Instance.new("TextLabel",f); vl.Size=UDim2.new(0,40,0,16); vl.Position=UDim2.new(1,-50,0,4)
    vl.BackgroundTransparency=1; vl.Text=tostring(def); vl.TextColor3=Color3.fromRGB(130,95,240)
    vl.TextSize=12; vl.Font=Enum.Font.GothamBold; vl.TextXAlignment=Enum.TextXAlignment.Right
    local dl=Instance.new("TextLabel",f); dl.Size=UDim2.new(1,-20,0,11); dl.Position=UDim2.new(0,12,0,20)
    dl.BackgroundTransparency=1; dl.Text=d; dl.TextColor3=Color3.fromRGB(85,82,118)
    dl.TextSize=9; dl.Font=Enum.Font.Gotham; dl.TextXAlignment=Enum.TextXAlignment.Left
    local track=Instance.new("Frame",f); track.Size=UDim2.new(1,-24,0,5); track.Position=UDim2.new(0,12,0,38)
    track.BackgroundColor3=Color3.fromRGB(42,40,56); track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
    local pct=(def-mn)/(mx-mn)
    local fill=Instance.new("Frame",track); fill.Size=UDim2.new(pct,0,1,0)
    fill.BackgroundColor3=Color3.fromRGB(100,65,210); fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    local fg=Instance.new("UIGradient",fill); fg.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(75,45,170)),ColorSequenceKeypoint.new(1,Color3.fromRGB(140,95,245))})
    local knob=Instance.new("Frame",track); knob.Size=UDim2.new(0,12,0,12); knob.Position=UDim2.new(pct,-6,0.5,-6)
    knob.BackgroundColor3=Color3.fromRGB(170,145,248); knob.BorderSizePixel=0; knob.ZIndex=2
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    local drag=false
    local hb=Instance.new("TextButton",f); hb.Size=UDim2.new(1,0,0,18); hb.Position=UDim2.new(0,0,0,32)
    hb.BackgroundTransparency=1; hb.Text=""
    local function upd(inp)
        local rel=math.clamp((inp.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        local v=math.floor(mn+(mx-mn)*rel)
        fill.Size=UDim2.new(rel,0,1,0); knob.Position=UDim2.new(rel,-6,0.5,-6); vl.Text=tostring(v); cb(v)
    end
    hb.MouseButton1Down:Connect(function() drag=true end)
    UIS.InputChanged:Connect(function(inp) if drag and inp.UserInputType==Enum.UserInputType.MouseMovement then upd(inp) end end)
    UIS.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
end

