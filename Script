local function safeWait(parent, name, timeout)
    timeout = timeout or 5
    local obj = parent:WaitForChild(name, timeout)
    if not obj then
        warn("Airport Hub: Could not find '" .. name .. "' in " .. parent.Name)
    end
    return obj
end
