-- ═══════════════════════════════════════
-- AUTO ARREST (TP MODE — fast)
-- ═══════════════════════════════════════

local function doArrestTP(npc)
    if arrestingNow[npc] then return end
    arrestingNow[npc] = true

    local root = npc:FindFirstChild("HumanoidRootPart")
    if not root then arrestingNow[npc]=nil; return end

    -- Clamp TP to within map bounds (avoid flying off map)
    local hrp = getHRP(); if not hrp then arrestingNow[npc]=nil; return end
    local npcPos = root.Position
    -- Only TP if NPC is in reasonable range (within 300 studs of origin)
    local mapCenter = Vector3.new(0, 5, 0)
    if (npcPos - mapCenter).Magnitude > 400 then
        arrestingNow[npc]=nil; return
    end

    -- Safe TP: offset behind NPC at same Y level
    local safePos = CFrame.new(npcPos) * CFrame.new(0, 0, 5)
    hrp.CFrame = safePos
    task.wait(0.25)

    -- Tase if not already
    local s = getNPCVars(npc)
    if not s.Tasered then
        if equipTool("Taser") then
            local c=getChar(); local tt=c and c:FindFirstChild("Taser")
            if tt then
                hrp=getHRP()
                if hrp and root.Parent then
                    local dir=(root.Position-hrp.Position).Unit
                    pcall(function() FireTaserEv:FireServer(tt, hrp.Position, dir) end)
                end
                task.wait(GS.NPCTasedTime or 4)
            end
        end
    end

    if not npc.Parent then arrestingNow[npc]=nil; return end
    local s2=getNPCVars(npc)
    if s2.Arrested or s2.InJail then arrestingNow[npc]=nil; return end

    -- TP to jail and fire arrest
    hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(JAIL_POS + Vector3.new(0, 3, 0))
        task.wait(0.3)
    end

    pcall(function() NPCArrestEv:FireServer(npc) end)
    pcall(function() MarkArrestEv:FireServer(npc) end)
    arrestCount = arrestCount + 1
    updateStatus(string.format("🚔 ARRESTED #%d — sent to jail!", arrestCount), Color3.fromRGB(255,160,60))
    task.wait(0.5)
    arrestingNow[npc] = nil
end

-- ═══════════════════════════════════════
-- AUTO ARREST (WALK MODE — stealth, no TP)
-- ═══════════════════════════════════════

local function doArrestWalk(npc)
    if arrestingNow[npc] then return end
    arrestingNow[npc] = true

    local root = npc:FindFirstChild("HumanoidRootPart")
    if not root then arrestingNow[npc]=nil; return end

    updateStatus("🚶 Walking to suspect...", Color3.fromRGB(180,180,80))

    -- Walk to NPC
    walkTo(root.Position, GS.TaserRange - 1)
    task.wait(0.2)

    if not npc.Parent then arrestingNow[npc]=nil; return end

    -- Tase
    local s=getNPCVars(npc)
    if not s.Tasered then
        if equipTool("Taser") then
            local c=getChar(); local tt=c and c:FindFirstChild("Taser")
            if tt then
                local hrp=getHRP(); root=npc:FindFirstChild("HumanoidRootPart")
                if hrp and root then
                    local dir=(root.Position-hrp.Position).Unit
                    pcall(function() FireTaserEv:FireServer(tt, hrp.Position, dir) end)
                    updateStatus("⚡ Tased! Waiting...", Color3.fromRGB(255,220,50))
                end
                task.wait(GS.NPCTasedTime or 4)
            end
        end
    end

    if not npc.Parent then arrestingNow[npc]=nil; return end
    local s2=getNPCVars(npc)
    if s2.Arrested or s2.InJail then arrestingNow[npc]=nil; return end

    -- Walk to jail
    updateStatus("🚶 Walking to jail...", Color3.fromRGB(180,180,80))
    walkTo(JAIL_POS, 5)
    task.wait(0.3)

    pcall(function() NPCArrestEv:FireServer(npc) end)
    pcall(function() MarkArrestEv:FireServer(npc) end)
    arrestCount = arrestCount + 1
    updateStatus(string.format("✅ WALKED & ARRESTED #%d!", arrestCount), Color3.fromRGB(100,220,130))
    task.wait(0.5)
    arrestingNow[npc] = nil
end

-- ═══════════════════════════════════════
-- AUTO ALLOW CLEAN
-- ═══════════════════════════════════════

local function doAllow(npc)
    if allowedNow[npc] then return end
    allowedNow[npc] = true
    task.wait(0.3 + math.random()*0.4)
    if npc.Parent then
        pcall(function() MarkCorrectEv:FireServer(npc) end)
        allowCount = allowCount + 1
        updateStatus()
    end
    task.wait(2)
    allowedNow[npc] = nil
end

