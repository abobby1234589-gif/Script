-- HELPERS
local function getChar() return LP.Character end
local function getHum() local c=getChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function getHRP() local c=getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getTool(n) local c=getChar(); return (c and c:FindFirstChild(n)) or LP.Backpack:FindFirstChild(n) end
local function equipTool(n)
    local t=getTool(n); if not t then return false end
    local c=getChar(); if not c then return false end
    if c:FindFirstChild(n) then return true end
    local h=getHum(); if not h then return false end
    h:EquipTool(t); task.wait(0.3); return c:FindFirstChild(n)~=nil
end
local function unequipAll() local h=getHum(); if h then h:UnequipTools() end; task.wait(0.15) end
local function rWait(b,j) task.wait(b+math.random()*(j or 0.3)) end

local function walkTo(pos,radius)
    radius=radius or 4
    local hrp=getHRP(); if not hrp then return false end
    local hum=getHum(); if not hum or hum.Health<=0 then return false end
    if (hrp.Position-pos).Magnitude<=radius then return true end
    local path=PathfindingService:CreatePath({AgentRadius=2,AgentHeight=5,AgentCanJump=true,AgentJumpHeight=7.2,AgentMaxSlope=45})
    local ok=pcall(function() path:ComputeAsync(hrp.Position,pos) end)
    if ok and path.Status==Enum.PathStatus.Success then
        for _,wp in ipairs(path:GetWaypoints()) do
            local m=getHRP(); if not m or (m.Position-pos).Magnitude<=radius then break end
            if wp.Action==Enum.PathWaypointAction.Jump then local h=getHum(); if h then h.Jump=true end end
            local h=getHum(); if not h or h.Health<=0 then return false end
            h:MoveTo(wp.Position); h.MoveToFinished:Wait()
        end
    else local h=getHum(); if h then h:MoveTo(pos); h.MoveToFinished:Wait() end end
    local n=getHRP(); return n and (n.Position-pos).Magnitude<=radius+3
end

local function getNPCFolder()
    if not WS then return nil end
    return WS:FindFirstChild("Storage") and WS.Storage:FindFirstChild("NormalStorage") and WS.Storage.NormalStorage:FindFirstChild("NPCWorkspace")
end
local function getNPCs()
    local l={}; local f=getNPCFolder()
    if f then for _,m in ipairs(f:GetChildren()) do if m:IsA("Model") and m:FindFirstChildOfClass("Humanoid") then table.insert(l,m) end end end
    return l
end
local function getVars(npc)
    local r={}; local p=npc:FindFirstChild("Properties"); if not p then return r end
    for _,f in ipairs(p:GetChildren()) do for _,v in ipairs(f:GetChildren()) do if v:IsA("BoolValue") then r[v.Name]=v.Value end end end
    return r
end
local function contrabandType(npc)
    local s=getVars(npc)
    if s.ContrabandReal then return "real" end
    if s.ContrabandFake then return "fake" end
    if s.FakePassport then return "passport" end
    return nil
end
local function isArrestable(npc)
    local s=getVars(npc); local h=npc:FindFirstChildOfClass("Humanoid")
    return (s.ContrabandReal or s.FakePassport) and not s.Arrested and not s.InJail and h and h.Health>0
end
local function isClean(npc)
    local s=getVars(npc); local h=npc:FindFirstChildOfClass("Humanoid")
    return not s.ContrabandReal and not s.ContrabandFake and not s.FakePassport and not s.Arrested and not s.InJail and not s.Tasered and not s.Hostile and h and h.Health>0
end

-- ACTIONS
local function taserNPC(npc)
    if not FireTaserEv then return false end
    local root=npc:FindFirstChild("HumanoidRootPart"); if not root then return false end
    if not equipTool("Taser") then return false end
    local c=getChar(); local tt=c and c:FindFirstChild("Taser"); if not tt then return false end
    walkTo(root.Position,(GS.TaserRange or 20)-2); rWait(0.1,0.1)
    local hrp=getHRP(); if not hrp then return false end
    if root.Parent then Cam.CFrame=CFrame.new(hrp.Position,root.Position) end; task.wait(0.05)
    local vp=Cam.ViewportSize; local ray=Cam:ViewportPointToRay(vp.X/2,vp.Y/2)
    pcall(function() FireTaserEv:FireServer(tt,ray.Origin,ray.Direction) end)
    task.wait(GS.TaserCooldown or 3); unequipAll(); return true
end

local function processArrestTP(npc)
    if arrestingNow[npc] then return end; arrestingNow[npc]=true
    local root=npc:FindFirstChild("HumanoidRootPart"); if not root then arrestingNow[npc]=nil; return end
    local hrp=getHRP(); if not hrp then arrestingNow[npc]=nil; return end
    hrp.CFrame=CFrame.new(root.Position)*CFrame.new(0,0,5); rWait(0.2,0.1)
    local s=getVars(npc); if not s.Tasered and not s.Arrested then taserNPC(npc) end
    if not npc.Parent then arrestingNow[npc]=nil; return end
    local s2=getVars(npc); if s2.Arrested or s2.InJail then arrestingNow[npc]=nil; return end
    hrp=getHRP(); if hrp then hrp.CFrame=CFrame.new(JAIL_POS+Vector3.new(0,3,0)) end; rWait(0.25,0.1)
    if equipTool("Arrest") and NPCArrestEv then pcall(function() NPCArrestEv:FireServer(npc) end); stats.arrests=stats.arrests+1 end
    rWait(0.5,0.2); unequipAll(); arrestingNow[npc]=nil
end

local function processArrestWalk(npc)
    if arrestingNow[npc] then return end; arrestingNow[npc]=true
    local root=npc:FindFirstChild("HumanoidRootPart"); if not root then arrestingNow[npc]=nil; return end
    local s=getVars(npc)
    if not s.Tasered then taserNPC(npc); task.wait((GS.NPCTasedTime or 4)-0.5) end
    if not npc.Parent then arrestingNow[npc]=nil; return end
    local s2=getVars(npc); if s2.Arrested or s2.InJail then arrestingNow[npc]=nil; return end
    walkTo(JAIL_POS,6); rWait(0.2,0.1)
    if equipTool("Arrest") and NPCArrestEv then pcall(function() NPCArrestEv:FireServer(npc) end); stats.arrests=stats.arrests+1 end
    rWait(0.5,0.2); unequipAll(); arrestingNow[npc]=nil
end

local function doAllow(npc)
    if not MarkCorrectEv or allowedNow[npc] then return end; allowedNow[npc]=true
    rWait(0.3,0.3)
    if npc.Parent and isClean(npc) then pcall(function() MarkCorrectEv:FireServer(npc) end); stats.allowed=stats.allowed+1 end
    task.wait(1.5); allowedNow[npc]=nil
end

