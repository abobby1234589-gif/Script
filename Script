local function clearESP() for _,o in ipairs(ESPObjs) do pcall(function() o:Destroy() end) end; table.clear(ESPObjs) end
local function buildESP()
    clearESP(); if not T.NPCESP then return end
    for _,npc in ipairs(getNPCs()) do
        local root=npc:FindFirstChild("HumanoidRootPart"); if not root then continue end
        local s=getVars(npc); local cb=contrabandType(npc)
        local info=s.Hostile and ESPColors.hostile or (cb and ESPColors[cb] or ESPColors.clean)
        local hl=Instance.new("Highlight",npc); hl.FillColor=info.fill; hl.OutlineColor=info.outline
        hl.FillTransparency=0.7; hl.OutlineTransparency=0; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
        table.insert(ESPObjs,hl)
        local bb=Instance.new("BillboardGui",root); bb.Size=UDim2.new(0,160,0,46); bb.StudsOffset=Vector3.new(0,4,0); bb.AlwaysOnTop=true
        table.insert(ESPObjs,bb)
        local t1=Instance.new("TextLabel",bb); t1.Size=UDim2.new(1,0,0,18); t1.BackgroundTransparency=1
        t1.TextColor3=Color3.fromRGB(255,255,255); t1.TextStrokeTransparency=0.4; t1.TextSize=12; t1.Font=Enum.Font.GothamBold; t1.Text=info.label
        local t2=Instance.new("TextLabel",bb); t2.Size=UDim2.new(1,0,0,14); t2.Position=UDim2.new(0,0,0,18); t2.BackgroundTransparency=1
        t2.TextColor3=info.sc; t2.TextStrokeTransparency=0.5; t2.TextSize=10; t2.Font=Enum.Font.GothamSemibold; t2.Text=info.sub
        local t3=Instance.new("TextLabel",bb); t3.Size=UDim2.new(1,0,0,12); t3.Position=UDim2.new(0,0,0,33); t3.BackgroundTransparency=1
        t3.TextColor3=Color3.fromRGB(180,170,220); t3.TextStrokeTransparency=0.5; t3.TextSize=9; t3.Font=Enum.Font.Gotham
        task.spawn(function()
            while bb.Parent and T.NPCESP do
                local m=getHRP(); if m and root.Parent then t3.Text=string.format("[%.0f studs]",(m.Position-root.Position).Magnitude) end
                task.wait(0.5)
            end
        end)
    end
end
local espTick=0
local espConn=RunService.Heartbeat:Connect(function(dt) if not T.NPCESP then return end; espTick=espTick+dt; if espTick>=3 then espTick=0; buildESP() end end)
