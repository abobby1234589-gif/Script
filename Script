local function getChar()  return LP.Character end
local function getHum()   local c=getChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function getHRP()   local c=getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getTool(n) local c=getChar(); return (c and c:FindFirstChild(n)) or LP.Backpack:FindFirstChild(n) end

local function equipTool(n)
    local t=getTool(n); if not t then return false end
    local c=getChar(); if not c then return false end
    if c:FindFirstChild(n) then return true end
    local h=getHum(); if not h then return false end
    h:EquipTool(t); task.wait(0.3)
    return c:FindFirstChild(n)~=nil
end

local function getNPCs()
    local list={}
    local folder = Workspace:FindFirstChild("WorkspaceScriptable")
        and Workspace.WorkspaceScriptable:FindFirstChild("Storage")
        and Workspace.WorkspaceScriptable.Storage:FindFirstChild("NormalStorage")
        and Workspace.WorkspaceScriptable.Storage.NormalStorage:FindFirstChild("NPCWorkspace")
    if folder then
        for _,npc in pairs(folder:GetChildren()) do
            if npc:IsA("Model") and npc:FindFirstChildOfClass("Humanoid") then
                table.insert(list,npc)
            end
        end
    end
    return list
end

local function getNPCVars(npc)
    local r={}
    local props=npc:FindFirstChild("Properties"); if not props then return r end
    for _,folder in pairs(props:GetChildren()) do
        for _,v in pairs(folder:GetChildren()) do
            if v:IsA("BoolValue") then r[v.Name]=v.Value end
        end
    end
    return r
end

local function getContrabandType(npc)
    local s=getNPCVars(npc)
    if s.ContrabandReal then return "real"     end
    if s.ContrabandFake then return "fake"     end
    if s.FakePassport   then return "passport" end
    return nil
end

-- Pathfind walk to position
local function walkTo(pos, radius)
    radius = radius or 4
    local hrp = getHRP(); if not hrp then return false end
    local hum = getHum(); if not hum or hum.Health<=0 then return false end
    if (hrp.Position-pos).Magnitude <= radius then return true end

    local path = PathfindingService:CreatePath({
        AgentRadius=2, AgentHeight=5,
        AgentCanJump=true, AgentJumpHeight=7.2, AgentMaxSlope=45
    })
    local ok = pcall(function() path:ComputeAsync(hrp.Position, pos) end)
    if ok and path.Status == Enum.PathStatus.Success then
        for _,wp in ipairs(path:GetWaypoints()) do
            local myHRP = getHRP()
            if not myHRP or (myHRP.Position-pos).Magnitude <= radius then break end
            if wp.Action == Enum.PathWaypointAction.Jump then
                local h=getHum(); if h then h.Jump=true end
            end
            local h=getHum(); if not h or h.Health<=0 then return false end
            h:MoveTo(wp.Position)
            h.MoveToFinished:Wait()
        end
    else
        local h=getHum(); if h then h:MoveTo(pos); h.MoveToFinished:Wait() end
    end
    local newHRP=getHRP()
    return newHRP and (newHRP.Position-pos).Magnitude <= radius+3
end

