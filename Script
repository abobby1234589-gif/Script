local function applySpeed(on) local h=getHum(); if h then h.WalkSpeed=on and speedVal or GS.PlayerWalkSpeed end end
local function applyInfSprint(on)
    if Conns.infSprint then Conns.infSprint:Disconnect(); Conns.infSprint=nil end
    if not on then applySpeed(T.Speed); return end
    Conns.infSprint=RunService.RenderStepped:Connect(function()
        local h=getHum(); if not h then return end; h.WalkSpeed=T.Speed and speedVal or GS.PlayerRunSpeed
        local pg=LP:FindFirstChild("PlayerGui"); local sb=pg and pg:FindFirstChild("ControlUI") and pg.ControlUI:FindFirstChild("SprintBarFrame")
        if sb then local bar=sb:FindFirstChild("Bar"); if bar then bar.Size=UDim2.new(1,0,1,0) end; sb.Visible=false end
    end); table.insert(_G.HubConns,Conns.infSprint)
end
local function applyNoclip(on)
    if Conns.noclip then Conns.noclip:Disconnect(); Conns.noclip=nil end
    if not on then return end
    Conns.noclip=RunService.Stepped:Connect(function()
        local c=getChar(); if not c then return end
        for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    end); table.insert(_G.HubConns,Conns.noclip)
end

